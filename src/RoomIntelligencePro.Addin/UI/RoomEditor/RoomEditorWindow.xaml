<Window x:Class="RoomIntelligencePro.Addin.UI.RoomEditor.RoomEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Room Intelligence Pro · Room Editor"
        Width="1480"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RoomIntelligencePro.Addin;component/UI/Styles/PremiumTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="86" />
        </Grid.RowDefinitions>

        <!-- Hero Header -->
        <Border Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,0,0,14"
                Style="{StaticResource TonalPanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Premium Revit Utility"
                               Foreground="{StaticResource TextSubBrush}"
                               FontSize="13" />
                    <TextBlock Text="Room Editor"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Glassmorphism · Tonal Layering · Bento Cards"
                               Foreground="{StaticResource TextSubBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        CornerRadius="12"
                        Padding="12,8"
                        Background="#2A3652"
                        BorderBrush="#5070A4"
                        BorderThickness="1">
                    <TextBlock Foreground="White"
                               FontWeight="SemiBold">
                        <Run Text="Room Count: " />
                        <Run Text="{Binding Rooms.Count}" />
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- Glass Sidebar -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,14,12"
                Style="{StaticResource GlassSidebarStyle}">
            <StackPanel>
                <TextBlock Text="Information Architecture"
                           Foreground="{StaticResource TextMainBrush}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <Border Style="{StaticResource TonalPanelStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Read Layer"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" />
                        <TextBlock Text="Number · Name · Area · Level"
                                   Foreground="White"
                                   Margin="0,4,0,0"
                                   FontSize="14" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TonalPanelStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Edit Layer"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" />
                        <TextBlock Text="Inline edit Name / Number"
                                   Foreground="White"
                                   Margin="0,4,0,0"
                                   FontSize="14" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TonalPanelStyle}">
                    <StackPanel>
                        <TextBlock Text="Action Layer"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" />
                        <TextBlock Text="Command Dock: Refresh / Save / Close"
                                   Foreground="White"
                                   Margin="0,4,0,0"
                                   FontSize="14" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Bento Workspace -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Margin="0,0,0,12"
                CornerRadius="22"
                Background="#8F121B2A"
                BorderBrush="#2D3C57"
                BorderThickness="1"
                Padding="14">
            <ListBox ItemsSource="{Binding Rooms}"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource BentoCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="{Binding LevelName}"
                                               Foreground="#9BD0FF"
                                               FontWeight="SemiBold"
                                               DockPanel.Dock="Left" />
                                    <TextBlock Text="{Binding AreaSquareMetersText, StringFormat={}{0} ㎡}"
                                               Foreground="{StaticResource TextSubBrush}"
                                               DockPanel.Dock="Right" />
                                </DockPanel>

                                <TextBlock Text="Number" Foreground="#9DB2CF" FontSize="12" />
                                <TextBox Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CardTextBoxStyle}" />

                                <TextBlock Text="Name" Foreground="#9DB2CF" FontSize="12" />
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CardTextBoxStyle}" />

                                <TextBlock Text="{Binding ElementId, StringFormat=ElementId: {0}}"
                                           Foreground="#7286A6"
                                           FontSize="11" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Command Dock -->
        <Border Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Style="{StaticResource DockStyle}">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSubBrush}"
                           FontSize="13"
                           DockPanel.Dock="Left" />

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource DockButtonStyle}" />
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryDockButtonStyle}" />
                    <Button Content="Close"
                            Command="{Binding CloseCommand}"
                            Margin="0"
                            Style="{StaticResource DockButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
