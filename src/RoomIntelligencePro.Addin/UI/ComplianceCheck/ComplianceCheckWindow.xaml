<Window x:Class="RoomIntelligencePro.Addin.UI.ComplianceCheck.ComplianceCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room Intelligence Pro · 规范检查"
        Width="1160"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RoomIntelligencePro.Addin;component/UI/Styles/PremiumTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource TonalPanelStyle}">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="规范检查结果" Foreground="{StaticResource TextMainBrush}" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="当前内置规则：最小面积、最小净高、最小门宽。" Foreground="{StaticResource TextSubBrush}" Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="28,0,0,0">
                    <Border Style="{StaticResource BentoCardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="违规总数" Foreground="{StaticResource TextSubBrush}" />
                            <TextBlock Text="{Binding TotalViolations}" Foreground="{StaticResource TextMainBrush}" FontSize="26" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource BentoCardStyle}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Error" Foreground="{StaticResource TextSubBrush}" />
                            <TextBlock Text="{Binding ErrorCount}" Foreground="#FF8080" FontSize="26" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource BentoCardStyle}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Warning" Foreground="{StaticResource TextSubBrush}" />
                            <TextBlock Text="{Binding WarningCount}" Foreground="{StaticResource AccentBrush}" FontSize="26" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource TonalPanelStyle}">
            <DataGrid ItemsSource="{Binding Violations}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="{StaticResource BgLayer2Brush}"
                      AlternatingRowBackground="#1E1E2A"
                      Foreground="{StaticResource TextMainBrush}"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeight="44">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="规则" Binding="{Binding RuleName}" Width="210" />
                    <DataGridTextColumn Header="级别" Binding="{Binding SeverityText}" Width="100" />
                    <DataGridTextColumn Header="问题描述" Binding="{Binding Message}" Width="*" />
                    <DataGridTextColumn Header="整改建议" Binding="{Binding SuggestedFix}" Width="320" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
