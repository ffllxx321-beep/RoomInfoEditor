<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BgBase">#0C1017</Color>
    <Color x:Key="BgLayer1">#121A27</Color>
    <Color x:Key="BgLayer2">#1A2435</Color>
    <Color x:Key="AccentBlue">#5F95FF</Color>
    <Color x:Key="AccentBlueStrong">#2D6DFF</Color>
    <Color x:Key="StrokeSoft">#33FFFFFF</Color>
    <Color x:Key="TextMain">#F2F6FF</Color>
    <Color x:Key="TextSub">#AFC0DA</Color>

    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
    <SolidColorBrush x:Key="BgLayer1Brush" Color="{StaticResource BgLayer1}" />
    <SolidColorBrush x:Key="BgLayer2Brush" Color="{StaticResource BgLayer2}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentBlue}" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource AccentBlueStrong}" />
    <SolidColorBrush x:Key="StrokeSoftBrush" Color="{StaticResource StrokeSoft}" />
    <SolidColorBrush x:Key="TextMainBrush" Color="{StaticResource TextMain}" />
    <SolidColorBrush x:Key="TextSubBrush" Color="{StaticResource TextSub}" />

    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A0F16" Offset="0" />
        <GradientStop Color="#121C2E" Offset="0.55" />
        <GradientStop Color="#0B111B" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassPanelBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#66FFFFFF" Offset="0" />
        <GradientStop Color="#22FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="GlassSidebarStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Background" Value="{StaticResource GlassPanelBrush}" />
        <Setter Property="BorderBrush" Value="#44FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" Color="#000000" Opacity="0.35" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TonalPanelStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="#B3192434" />
        <Setter Property="BorderBrush" Value="#2F8AAEFF" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="BentoCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="#CB1A2536" />
        <Setter Property="BorderBrush" Value="#3A4D6D" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="10" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" Color="#000000" Opacity="0.28" ShadowDepth="4" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DockStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="#D20F1725" />
        <Setter Property="BorderBrush" Value="#2E4060" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="20,12" />
    </Style>

    <Style x:Key="DockButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="42" />
        <Setter Property="MinWidth" Value="118" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="#1B2B42" />
        <Setter Property="BorderBrush" Value="#3B567A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#264670" />
                            <Setter Property="BorderBrush" Value="#6FA8FF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#1F3B5E" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryDockButtonStyle" TargetType="Button" BasedOn="{StaticResource DockButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AccentStrongBrush}" />
        <Setter Property="BorderBrush" Value="#86ABFF" />
    </Style>

    <Style x:Key="CardTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#0F1828" />
        <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        <Setter Property="BorderBrush" Value="#3D5476" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Margin" Value="0,4,0,10" />
    </Style>

</ResourceDictionary>
